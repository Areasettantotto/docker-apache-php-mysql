# docker-apache-php-mysql
# File di ambiente (contiene password reali, NON versionare)
.env

# Dati e volumi runtime Docker
mysql-data/*

# Log runtime (NON versionare, ma puoi fare eccezione per logs/.gitkeep)
logs/*
!logs/.gitkeep

# File temporanei di sistema/editor
*.swp
*.swo
*.tmp
.DS_Store
.idea/

# Backup o file generati
*.bak
*.old
.docker/xdebug.ini
.vscode/

# Do not version database dumps
mysql/dump.sql
